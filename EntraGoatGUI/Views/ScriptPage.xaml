<DockPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           Margin="16">
    <!-- Header -->
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
        <TextBlock x:Name="HeaderText"
                   Foreground="{{Primary}}" FontSize="18" FontWeight="Bold"
                   FontFamily="{{FontUI}}"/>
        <TextBlock x:Name="PathText"
                   Foreground="{{TextMuted}}" FontSize="11"
                   FontFamily="{{FontMono}}" TextWrapping="Wrap" Margin="0,4,0,0"/>
    </StackPanel>

    <!-- Action buttons -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,12,0,0">
        <Button x:Name="CopyButton" Content="Copy"
                Background="Transparent" Foreground="{{Primary}}" BorderBrush="{{Primary}}"
                BorderThickness="1" Padding="12,6" Margin="0,0,8,0" Cursor="Hand"/>
        <Button x:Name="SaveButton" Content="Save As..."
                Background="Transparent" Foreground="{{TextPrimary}}" BorderBrush="{{BorderColor}}"
                BorderThickness="1" Padding="12,6" Margin="0,0,8,0" Cursor="Hand"/>
        <Button x:Name="RunButton" Content="Run in this session"
                Background="{{Warning}}" Foreground="#0A0A0A" BorderThickness="0"
                Padding="12,6" Margin="0,0,8,0" Cursor="Hand" FontWeight="Bold"/>
    </StackPanel>

    <!-- Script content -->
    <Border BorderBrush="{{BorderColor}}" BorderThickness="1" CornerRadius="4"
            Background="{{BgDark}}">
        <TextBox x:Name="ScriptBox"
                 Background="{{BgDark}}" Foreground="{{TextPrimary}}"
                 BorderThickness="0" Padding="12"
                 FontFamily="{{FontMono}}" FontSize="12"
                 IsReadOnly="True" AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap"/>
    </Border>
</DockPanel>
