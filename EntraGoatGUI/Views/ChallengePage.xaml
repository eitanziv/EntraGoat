<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Background ram icon watermark (fixed, does not scroll) -->
    <Image x:Name="ChallengeIcon" Opacity="0.06" Stretch="Uniform"
           Width="500" Height="500"
           HorizontalAlignment="Center" VerticalAlignment="Center"
           IsHitTestVisible="False"/>

    <!-- Scrollable content on top -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="32,24">
        <StackPanel MaxWidth="900" HorizontalAlignment="Stretch">
        <!-- Badges row -->
        <StackPanel x:Name="BadgesPanel" Orientation="Horizontal" Margin="0,0,0,12"/>

        <!-- Title -->
        <TextBlock x:Name="TitleText" FontSize="28" FontWeight="Bold"
                   Foreground="{{Primary}}" FontFamily="{{FontUI}}" TextWrapping="Wrap"
                   Margin="0,0,0,12"/>

        <!-- Description -->
        <Border Background="{{BgMedium}}" BorderBrush="{{BorderColor}}" BorderThickness="1"
                CornerRadius="6" Padding="14" Margin="0,0,0,18">
            <TextBlock x:Name="DescriptionText" Foreground="{{TextSecondary}}"
                       FontFamily="{{FontUI}}" FontSize="13" TextWrapping="Wrap"/>
        </Border>

        <!-- Starting credentials -->
        <Border BorderBrush="{{Primary}}" BorderThickness="1" CornerRadius="6"
                Background="#0F1F2A" Padding="14" Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Starting Credentials" FontWeight="Bold"
                           Foreground="{{Warning}}" FontFamily="{{FontUI}}" FontSize="14"
                           Margin="0,0,0,10"/>
                <StackPanel x:Name="CredentialsPanel"/>
            </StackPanel>
        </Border>

        <!-- Challenge resources -->
        <TextBlock Text="Challenge Resources" FontWeight="Bold" Foreground="{{TextPrimary}}"
                   FontFamily="{{FontUI}}" FontSize="14" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
            <Button x:Name="SetupButton" Content="&#x25B6; Run Setup"
                    Background="{{Warning}}" Foreground="#0A0A0A" BorderThickness="0"
                    Padding="12,6" Margin="0,0,10,0" Cursor="Hand" FontWeight="Bold"/>
            <Button x:Name="CleanupButton" Content="&#x25B6; Run Cleanup"
                    Background="Transparent" Foreground="{{Danger}}" BorderBrush="{{Danger}}"
                    BorderThickness="1" Padding="12,6" Margin="0,0,10,0" Cursor="Hand"/>
            <Button x:Name="SolutionButton" Content="View Solution"
                    Background="Transparent" Foreground="{{TextSecondary}}" BorderBrush="{{TextSecondary}}"
                    BorderThickness="1" Padding="12,6" Cursor="Hand"/>
        </StackPanel>

        <!-- Terminal hint (shown after a script is launched) -->
        <TextBlock x:Name="TerminalHintText" Visibility="Collapsed"
                   Text="&#x1F4BB; Script launched — check your terminal for scenario output and credentials."
                   Foreground="{{TextSecondary}}" FontFamily="{{FontUI}}" FontSize="12"
                   FontStyle="Italic" Margin="0,0,0,18"/>

        <!-- Flag submit / completed message -->
        <ContentControl x:Name="FlagArea" Margin="0,0,0,18"/>

        <!-- Hints -->
        <TextBlock Text="Hints &amp; Guidance" FontWeight="Bold" Foreground="{{TextPrimary}}"
                   FontFamily="{{FontUI}}" FontSize="14" Margin="0,0,0,8"/>
        <StackPanel x:Name="HintsPanel"/>
        </StackPanel>
    </ScrollViewer>
</Grid>
