<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EntraGoat"
        Width="1280" Height="860"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{{BgDarkest}}">
    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{{BgDark}}"/>
        </Style>
    </Window.Resources>
    <DockPanel>
        <!-- Persistent navigation bar -->
        <Border x:Name="NavBar" DockPanel.Dock="Top" Background="{{BgDark}}" BorderBrush="{{BorderColor}}" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BackButton" Grid.Column="0" Content="&#x2190; Back"
                        Background="Transparent" Foreground="{{Primary}}" BorderBrush="{{Primary}}"
                        BorderThickness="1" Padding="10,5" Cursor="Hand" Visibility="Collapsed"/>
                <TextBlock x:Name="BreadcrumbText" Grid.Column="1" Text="Home"
                           Foreground="{{TextSecondary}}" FontFamily="{{FontUI}}" FontSize="13"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <Button x:Name="PrevButton" Grid.Column="2" Content="&#x2190; Previous"
                        Background="Transparent" Foreground="{{TextPrimary}}" BorderBrush="{{BorderColor}}"
                        BorderThickness="1" Padding="10,5" Margin="0,0,8,0" Cursor="Hand" Visibility="Collapsed"/>
                <Button x:Name="NextButton" Grid.Column="3" Content="Next &#x2192;"
                        Background="Transparent" Foreground="{{TextPrimary}}" BorderBrush="{{BorderColor}}"
                        BorderThickness="1" Padding="10,5" Cursor="Hand" Visibility="Collapsed"/>
                <!-- Zoom controls -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Button x:Name="ZoomOutButton" Content="&#x2212;" FontSize="16" FontWeight="Bold"
                            Background="Transparent" Foreground="{{TextPrimary}}" BorderBrush="{{BorderColor}}"
                            BorderThickness="1" Width="28" Height="28" Cursor="Hand" Padding="0"/>
                    <TextBlock x:Name="ZoomLabel" Text="100%" Foreground="{{TextSecondary}}"
                               FontFamily="{{FontUI}}" FontSize="11" VerticalAlignment="Center"
                               Margin="6,0,6,0" MinWidth="36" TextAlignment="Center"/>
                    <Button x:Name="ZoomInButton" Content="+" FontSize="16" FontWeight="Bold"
                            Background="Transparent" Foreground="{{TextPrimary}}" BorderBrush="{{BorderColor}}"
                            BorderThickness="1" Width="28" Height="28" Cursor="Hand" Padding="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Dynamic content area -->
        <Grid>
            <Border x:Name="GlowLayer" IsHitTestVisible="False"/>
            <ContentControl x:Name="PageHost"/>
        </Grid>
    </DockPanel>
</Window>
