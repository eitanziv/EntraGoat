<ScrollViewer xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="40,30">
    <StackPanel HorizontalAlignment="Center" MaxWidth="1000">
        <!-- Logo -->
        <Image x:Name="LogoImage" Height="360" Margin="0,0,0,0" HorizontalAlignment="Center"/>

        <!-- Subtitle -->
        <TextBlock Text="Sharpen your Entra ID attack skills with hands-on privilege escalation scenarios. Each scenario drops you into a realistic breach: enumerate permissions, chain misconfigurations, escalate privileges to log in as Global Admin to prove tenant dominance."
                   Foreground="{{TextSecondary}}"
                   FontFamily="{{FontUI}}"
                   FontSize="14"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   MaxWidth="640"
                   Margin="0,0,0,28"
                   HorizontalAlignment="Center"/>

        <!-- Stats panel -->
        <StackPanel x:Name="StatsPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,32"/>

        <!-- Challenge cards grid -->
        <ItemsControl x:Name="CardsItems">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </StackPanel>
</ScrollViewer>
